def basic_chatbot():
    print("Chatbot: Hello! I am a simple bot. How can I help you today?")
    print("(Type 'bye' to exit)")

    while True:
        user_input = input("You: ").lower()

        # Logic for predefined replies
        if "hello" in user_input or "hi" in user_input:
            print("Chatbot: Hi there! How's your day going?")
        
        elif "how are you" in user_input:
            print("Chatbot: I'm just a program, but I'm doing great! How about you?")
        
        elif "your name" in user_input:
            print("Chatbot: I am the CodeAlpha Basic Chatbot.")

        elif "fine" in user_input or "good" in user_input:
            print("Chatbot: I'm glad to hear that!")

        elif "thanks" in user_input or "thank you" in user_input:
            print("Chatbot: You're very welcome!")

        elif "bye" in user_input:
            print("Chatbot: Goodbye! Have a great day!")
            break
        
        else:
            print("Chatbot: I'm sorry, I don't understand that. Could you try saying 'hello'?")

if __name__ == "__main__":
    basic_chatbot()